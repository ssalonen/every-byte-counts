# fastlane lanes for Every Byte Counts (iOS only).
#
# During the migration the important lane is `probe` (see fastlane-probe.yml):
# it builds a real App-Store-signed archive but NEVER uploads, then leaves the
# IPA on disk so the workflow can prove the App Group entitlement survived. Once
# the probe is consistently green we port its build to a `beta` lane that adds
# upload_to_testflight, and delete the probe.

default_platform(:ios)

APP_ID    = "fi.mailhub.everybytecounts"
WIDGET_ID = "fi.mailhub.everybytecounts.widget"
PROJECT   = "EveryByteCounts.xcodeproj"
SCHEME    = "EveryByteCounts"
APP_TARGET    = "EveryByteCounts"
WIDGET_TARGET = "EveryByteCountsWidgetExtension"
# Declared entitlements — the source of truth re-asserted after Xcode packaging.
APP_ENTITLEMENTS    = "App/EveryByteCounts/EveryByteCounts.entitlements"
WIDGET_ENTITLEMENTS = "Widget/EveryByteCountsWidget/EveryByteCountsWidget.entitlements"

platform :ios do
  desc "Sync signing material (read-only on CI) without building anything"
  lane :certificates do
    # force: true so this also creates a dedicated, password-known keychain when
    # run locally (e.g. seeding from a Mac). Without it, match installs into the
    # login keychain and can't run `security set-key-partition-list`
    # non-interactively — the identity never forms and match reports "could not
    # find the newly generated certificate installed" (errSecInternalComponent).
    setup_ci(force: true)
    match(api_key: asc_api_key, type: "appstore", readonly: FastlaneCore::Helper.ci?)
  end

  # TEMPORARY diagnostic lane. Builds a signed, exported IPA to ./build without
  # touching App Store Connect, so we can iterate on Theme B (does the App Group
  # entitlement reach the shipped binary?) via CI, cheaply and with no risk of a
  # stray TestFlight upload. Deleted once release.yml runs the real `beta` lane.
  desc "TEMPORARY: build a signed IPA WITHOUT uploading, for App Group diagnosis"
  lane :probe do
    setup_ci
    key = asc_api_key

    # readonly by default. Set MATCH_READONLY=false (needs a *write* deploy key
    # and an API key allowed to manage profiles) to regenerate profiles from CI
    # after changing App-ID capabilities, instead of re-seeding from a Mac.
    match(
      api_key: key,
      type: "appstore",
      readonly: ENV["MATCH_READONLY"] != "false",
    )

    # Stamp manual signing + the match profiles into the freshly generated
    # project. This keeps project.yml free of any signing settings (the source
    # of much of the XcodeGen pain) — fastlane owns signing at build time.
    apply_signing(APP_TARGET,    ENV.fetch("sigh_#{APP_ID}_appstore_profile-name"))
    apply_signing(WIDGET_TARGET, ENV.fetch("sigh_#{WIDGET_ID}_appstore_profile-name"))

    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
    archive_path = File.expand_path("build/EveryByteCounts.xcarchive")

    # 1. Archive only — no IPA yet, so we can fix the archive before it's packaged.
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      skip_package_ipa: true,
      archive_path: archive_path,
      xcargs: [
        "MARKETING_VERSION=0.0.1",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
      ].join(" "),
    )

    # 2. Xcode 26 strips declared capabilities (e.g. App Groups) while packaging
    #    the archive, even though the match profiles authorise them (proven by the
    #    probe's profile dump). Re-assert each target's declared .entitlements onto
    #    the archived binary before export; exportArchive preserves entitlements
    #    already present in a signature. Generic — restores whatever the
    #    .entitlements files declare, not just App Groups.
    restore_declared_entitlements(archive_path)

    # 3. Export the signed IPA from the re-signed archive (no upload).
    build_app(
      skip_build_archive: true,
      archive_path: archive_path,
      output_directory: "build",
      output_name: "EveryByteCounts.ipa",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        signingCertificate: "Apple Distribution",
        provisioningProfiles: {
          APP_ID    => ENV.fetch("sigh_#{APP_ID}_appstore_profile-name"),
          WIDGET_ID => ENV.fetch("sigh_#{WIDGET_ID}_appstore_profile-name"),
        },
      },
    )
    UI.success("IPA built at build/EveryByteCounts.ipa — the workflow verifies the App Group next.")
  end
end

# App Store Connect API key from the existing repo secrets. key_content is the
# raw .p8 text (not base64), matching how APP_STORE_CONNECT_API_KEY_P8 is stored.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_P8"),
    is_key_content_base64: false,
    in_house: false, # standard Developer Program, NOT enterprise
  )
end

# Re-sign each archived bundle with its DECLARED entitlements merged back in.
# Xcode 26 strips some declared capabilities (e.g. App Groups) while packaging
# the archive even though the profile authorises them; this re-asserts whatever
# the target's .entitlements file declares — App Groups today, whatever is added
# later — while keeping Xcode-injected keys. exportArchive preserves entitlements
# already present in a signature. Widget (nested) is signed before the app
# (inside-out). Uses the Apple Distribution identity match installed into
# setup_ci's keychain.
def restore_declared_entitlements(archive_path)
  app = "#{archive_path}/Products/Applications/EveryByteCounts.app"
  resign_with_declared(Dir["#{app}/PlugIns/*.appex"].first, File.expand_path(WIDGET_ENTITLEMENTS))
  resign_with_declared(app, File.expand_path(APP_ENTITLEMENTS))
end

def resign_with_declared(bundle, declared)
  return if bundle.nil?
  tool = File.expand_path("scripts/entitlements.py")
  sh(<<~BASH)
    set -euo pipefail
    BUNDLE="#{bundle}"
    DECLARED="#{declared}"
    IDENTITY="Apple Distribution"
    KCARG=""
    [ -n "${MATCH_KEYCHAIN_NAME:-}" ] && KCARG="--keychain ${MATCH_KEYCHAIN_NAME}"
    signed="$(mktemp)"
    merged="$(mktemp)"
    # Start from what Xcode signed in (identifiers, team-id, get-task-allow,
    # beta-reports-active) and re-assert the declared capabilities on top.
    codesign -d --entitlements :- "$BUNDLE" > "$signed" 2>/dev/null
    plutil -convert xml1 "$signed"
    if [ -f "$DECLARED" ]; then
      python3 "#{tool}" merge "$signed" "$DECLARED" "$merged"
    else
      cp "$signed" "$merged"
    fi
    codesign --force --sign "$IDENTITY" $KCARG --entitlements "$merged" "$BUNDLE"
    echo "re-signed $(basename "$BUNDLE"); entitlements now:"
    codesign -d --entitlements :- "$BUNDLE" 2>/dev/null | plutil -p -
  BASH
end

def apply_signing(target, profile_name)
  update_code_signing_settings(
    path: PROJECT,
    use_automatic_signing: false,
    team_id: ENV.fetch("APPLE_TEAM_ID"),
    code_sign_identity: "Apple Distribution",
    profile_name: profile_name,
    targets: [target],
    build_configurations: ["Release"],
  )
end
